DATABASE_URL=sqlite://data/registry.db?mode=rwc
BLOB_DIR=data/blobs
BASE_URL=http://localhost:3000
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# OAUTH_TOKEN_KEY=generate-a-random-32-char-string

# S3-compatible blob storage (Cloudflare R2, MinIO, AWS S3).
# Set BLOB_S3_BUCKET to store tarballs in object storage instead of BLOB_DIR —
# required for stateless / multi-instance deploys. Leave unset for local filesystem.
# BLOB_S3_BUCKET=sema-packages
# BLOB_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# BLOB_S3_REGION=auto
# BLOB_S3_ACCESS_KEY_ID=
# BLOB_S3_SECRET_ACCESS_KEY=

# IP-keyed request rate limiting (on by default). Disable only behind a gateway
# that already rate-limits. RPS is sustained per-IP; BURST is the allowance.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_RPS=20
# RATE_LIMIT_BURST=40

# Database connection pool size (read concurrency).
# DATABASE_MAX_CONNECTIONS=10

# Observability — built in, off until configured (see DEPLOYMENT.md#observability).
# Traces: none (default) | file | otlp
# OTEL_TRACES_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_TRACES_SAMPLER_ARG=0.05
# Prometheus metrics at /metrics:
# METRICS_ENABLED=true
